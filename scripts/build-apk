#!/usr/bin/env bash
# One-step APK build.
# Usage: build-apk
# Builds dist/janus_unisound.apk (versionless, overwrites on each run).

set -e

# 确定项目根目录（从脚本自身位置推导，不依赖 DEVENV_ROOT）
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd -P)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd -P)"
cd "$PROJECT_DIR"

TOOLS_DIR="$PROJECT_DIR/tools"
DIST_DIR="$PROJECT_DIR/dist"
SMALI_BASE="$PROJECT_DIR/smali-base"
ORIGINAL_APK="$PROJECT_DIR/device_original.apk"
JANUS_SCRIPT="$PROJECT_DIR/scripts/build_janus_v2.py"
DX="${ANDROID_HOME}/build-tools/30.0.3/dx"

# ── 前置检查 ──────────────────────────────────
if [ ! -f "$ORIGINAL_APK" ]; then
  echo "ERROR: device_original.apk not found at $ORIGINAL_APK"
  exit 1
fi
if [ ! -f "$TOOLS_DIR/smali.jar" ]; then
  echo "ERROR: $TOOLS_DIR/smali.jar not found"
  exit 1
fi
if [ ! -f "$TOOLS_DIR/baksmali.jar" ]; then
  echo "ERROR: $TOOLS_DIR/baksmali.jar not found"
  exit 1
fi
if [ ! -f "$JANUS_SCRIPT" ]; then
  echo "ERROR: $JANUS_SCRIPT not found"
  exit 1
fi

mkdir -p "$DIST_DIR"

# ── 生成/复用持久化 smali 基准备 ──────────────
# 注意：smali-base/ 在项目根目录（不是 build/ 下），不会被 gradle clean 删除
if [ ! -d "$SMALI_BASE" ]; then
  echo "=== [0a] Generating smali-base from device_original.apk ==="
  EXTRACT_DIR="/tmp/janus_build_base_extract"
  mkdir -p "$EXTRACT_DIR"
  unzip -o "$ORIGINAL_APK" classes.dex -d "$EXTRACT_DIR"
  java -jar "$TOOLS_DIR/baksmali.jar" d "$EXTRACT_DIR/classes.dex" -o "$SMALI_BASE"
  rm -rf "$EXTRACT_DIR"
  COUNT=$(find "$SMALI_BASE" -name '*.smali' | wc -l | tr -d ' ')
  echo "  Generated smali-base at $SMALI_BASE ($COUNT files)"
fi


echo "=== [1/7] Compiling Java sources ==="
# Gradle compiles both source roots configured in app/build.gradle:
#   java/          = our added/overridden code
#   java-original/ = factory dependency code
# java-jadx-reference/ is documentation only and is never compiled.
./gradlew clean :app:assembleRelease

echo "=== [2/7] Extracting modified .class files ==="
CLASSES_DIR="/tmp/janus_build_classes"
rm -rf "$CLASSES_DIR"
mkdir -p "$CLASSES_DIR/com/phicomm/speaker/device"
mkdir -p "$CLASSES_DIR/com/phicomm/speaker/device/ui"

# Only these two injection groups enter the factory smali base. Their source
# location is irrelevant here because Gradle merges the two compiling roots.
cp -r app/build/intermediates/javac/release/classes/com/phicomm/speaker/device/custom \
  "$CLASSES_DIR/com/phicomm/speaker/device/" 2>/dev/null || true
cp app/build/intermediates/javac/release/classes/com/phicomm/speaker/device/ui/ExampleANTEngineInitializer*.class \
  "$CLASSES_DIR/com/phicomm/speaker/device/ui/" 2>/dev/null || true

CLASS_COUNT=$(find "$CLASSES_DIR" -name "*.class" | wc -l | tr -d ' ')
echo "  Extracted $CLASS_COUNT class files"

echo "=== [3/7] Compiling DEX ==="
DEX_DIR="/tmp/janus_build_dex"
rm -rf "$DEX_DIR"
mkdir -p "$DEX_DIR"
"$DX" --dex --output="$DEX_DIR/classes.dex" "$CLASSES_DIR"

echo "=== [4/7] DEX → smali ==="
SMALI_DIR="/tmp/janus_build_smali"
rm -rf "$SMALI_DIR"
java -jar "$TOOLS_DIR/baksmali.jar" d "$DEX_DIR/classes.dex" -o "$SMALI_DIR"

echo "=== [5/7] Injecting smali into base ==="
WORK_SMALI="/tmp/janus_build_work_smali"
rm -rf "$WORK_SMALI"
cp -r "$SMALI_BASE" "$WORK_SMALI"

# 整包替换 custom/（覆盖注入）
rm -rf "$WORK_SMALI/com/phicomm/speaker/device/custom" 2>/dev/null || true
if [ -d "$SMALI_DIR/com/phicomm/speaker/device/custom" ]; then
  cp -r "$SMALI_DIR/com/phicomm/speaker/device/custom" \
    "$WORK_SMALI/com/phicomm/speaker/device/"
fi

# 同名覆盖入口类
if [ -f "$SMALI_DIR/com/phicomm/speaker/device/ui/ExampleANTEngineInitializer.smali" ]; then
  cp "$SMALI_DIR/com/phicomm/speaker/device/ui/ExampleANTEngineInitializer.smali" \
    "$WORK_SMALI/com/phicomm/speaker/device/ui/"
fi

INJECTED_COUNT=$(find "$WORK_SMALI/com/phicomm/speaker/device/custom" -name "*.smali" 2>/dev/null | wc -l | tr -d ' ')
echo "  Injected $INJECTED_COUNT custom smali files"

echo "=== [6/7] smali → final DEX ==="
DEX_OUTPUT="$DIST_DIR/classes_new.dex"
java -jar "$TOOLS_DIR/smali.jar" a -o "$DEX_OUTPUT" "$WORK_SMALI"

echo "=== [7/7] Building Janus APK ==="
APK_OUTPUT="$DIST_DIR/janus_unisound.apk"
python3 "$JANUS_SCRIPT" \
  "$ORIGINAL_APK" \
  "$DEX_OUTPUT" \
  "$APK_OUTPUT"

echo ""
echo "✅ APK built: $APK_OUTPUT"
echo "   DEX:       $DEX_OUTPUT"
